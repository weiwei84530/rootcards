# Gemini key material. NEVER commit a key: GitHub reports exposed GCP keys
# to Google, which auto-revokes them within hours (learned the hard way).
# The app reads the key from localStorage (Settings tab); js/config.js is a
# local dev fallback generated by scripts/gen-config.mjs.
.env
js/config.js

# Local Claude Code settings (auto-accumulated permissions)
.claude/

# Word-generation working files (batch inputs/outputs merge into data/words.json)
data/batches/

# OS noise
Thumbs.db
.DS_Store
